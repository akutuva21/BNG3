###
begin model
begin parameters
  kf_0 3000.0
  kr_0 8000.0
  kf_1 1500.0
  kr_1 16000.0
  kf_2 30000.0
  kr_2 700.0
  kf_3 3000.0
  kr_3 8.64
  kf_4 1500.0
  kr_4 17.28
  kf_5 0.54
  kr_5 10800.0
  kf_6 130.0
  kr_6 2740.0
  kf_7 3000.0
  kr_7 4.0
  kf_8 1500.0
  kr_8 8.0
  kf_9 19.7
  kr_9 3.74
  kf_10 19.85
  kr_10 1.74
  kf_11 20.0
  kr_11 0.81
  kf_12 3000.0
  kr_12 4.0
  kf_13 1500.0
  kr_13 8.0
  kf_14 0.05
  kr_14 0.0012
  kf_15 0.05
  kr_15 0.0012
  kf_16 0.05
  kr_16 0.0012
  t2 20.0
end parameters
begin compartments
  comp1 3 1e-16 #compartment1
end compartments
begin molecule types
  BasalACh2()
  IntermediateACh()
  ActiveACh()
  Active()
  BasalACh()
  Basal()
  DesensitisedACh2()
  Desensitised()
  IntermediateACh2()
  DesensitisedACh()
  Intermediate()
  ActiveACh2()
end molecule types
begin seed species
  @comp1:Basal() 1.66057788110262e-21 #Basal #B
end seed species
begin observables
  Species BasalACh2 @comp1:BasalACh2() #BasalACh2
  Species IntermediateACh @comp1:IntermediateACh() #IntermediateACh
  Species ActiveACh @comp1:ActiveACh() #ActiveACh
  Species Active @comp1:Active() #Active
  Species BasalACh @comp1:BasalACh() #BasalACh
  Species Basal @comp1:Basal() #Basal
  Species DesensitisedACh2 @comp1:DesensitisedACh2() #DesensitisedACh2
  Species Desensitised @comp1:Desensitised() #Desensitised
  Species IntermediateACh2 @comp1:IntermediateACh2() #IntermediateACh2
  Species DesensitisedACh @comp1:DesensitisedACh() #DesensitisedACh
  Species Intermediate @comp1:Intermediate() #Intermediate
  Species ActiveACh2 @comp1:ActiveACh2() #ActiveACh2
end observables
begin reaction rules
  React0: Basal()@comp1 <-> BasalACh()@comp1 kf_0,kr_0
  React1: BasalACh()@comp1 <-> BasalACh2()@comp1 kf_1,kr_1
  React2: BasalACh2()@comp1 <-> ActiveACh2()@comp1 kf_2,kr_2
  React3: Active()@comp1 <-> ActiveACh()@comp1 kf_3,kr_3
  React4: ActiveACh()@comp1 <-> ActiveACh2()@comp1 kf_4,kr_4
  React5: Basal()@comp1 <-> Active()@comp1 kf_5,kr_5
  React6: BasalACh()@comp1 <-> ActiveACh()@comp1 kf_6,kr_6
  React7: Intermediate()@comp1 <-> IntermediateACh()@comp1 kf_7,kr_7
  React8: IntermediateACh()@comp1 <-> IntermediateACh2()@comp1 kf_8,kr_8
  React9: Active()@comp1 <-> Intermediate()@comp1 kf_9,kr_9
  React10: ActiveACh()@comp1 <-> IntermediateACh()@comp1 kf_10,kr_10
  React11: ActiveACh2()@comp1 <-> IntermediateACh2()@comp1 kf_11,kr_11
  React12: Desensitised()@comp1 <-> DesensitisedACh()@comp1 kf_12,kr_12
  React13: DesensitisedACh()@comp1 <-> DesensitisedACh2()@comp1 kf_13,kr_13
  React14: Intermediate()@comp1 <-> Desensitised()@comp1 kf_14,kr_14
  React15: IntermediateACh()@comp1 <-> DesensitisedACh()@comp1 kf_15,kr_15
  React16: IntermediateACh2()@comp1 <-> DesensitisedACh2()@comp1 kf_16,kr_16
end reaction rules
end model